# Salin ke `.env` di folder backend (opsional)
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///./data/codebuddy.db

# Ollama — sesuaikan model (contoh: gemma3:4b, gemma2:2b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

KODE_MAKSIMAL_PANJANG=8000

# CORS (opsional) — daftar origin di utils/config.py secara default sudah cocok untuk lokal.
# Untuk produksi, edit allowed_origins di config atau extend lewat kode.

# Rate limit per menit per IP (opsional) — lihat utils/config.py:
# RATE_LIMIT_PER_MINUTE, RATE_LIMIT_OCR, RATE_LIMIT_AGENT
